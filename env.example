# .env.example
# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=monitoring_db
# DATABASE_URL=postgresql://postgres:change-me@localhost:5432/monitoring_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
# REDIS_URL=redis://:change-me@redis:6379/0
# --- Redis Sentinel (HA, optional) ---
# Set REDIS_SENTINELS to enable Sentinel discovery for both the app and Celery
# (the redis-sentinel-1/2/3 services in docker-compose.prod.yml monitor "mymaster").
# REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_MASTER_NAME=mymaster
# REDIS_SENTINEL_PASSWORD=

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-random-secret
ADMIN_USERNAME=admin
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD=$2b$12$replace-with-bcrypt-hash
WEBHOOK_API_KEY=change-me

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=-000000000
TELEGRAM_CHAT_ID_WARNING=-000000000
TELEGRAM_CHAT_ID_CRITICAL=-000000000

# --- i-doit (ITSM / CMDB) ---
I_DOIT_API_KEY=change-me
I_DOIT_API_URL=http://idoit/src/jsonrpc.php
IDOIT_DB_NAME=idoit
IDOIT_DB_USER=idoit
IDOIT_DB_PASS=change-me
IDOIT_DB_ROOT_PASSWORD=change-me
IDOIT_ADMIN_PASS=admin

# --- Kafka ---
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- ClickHouse ---
CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=sit_center

# --- LDAP ---
LDAP_ENABLED=false
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=change-me
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})
# JSON: {"CN=Admins,DC=example,DC=com": "admin", "CN=Viewers,DC=example,DC=com": "viewer"}
LDAP_GROUP_ROLE_MAP={}

# --- OIDC / Keycloak SSO ---
OIDC_ENABLED=false
OIDC_ISSUER_URL=http://keycloak:8080/realms/sit-center
OIDC_CLIENT_ID=sit-center-api
OIDC_CLIENT_SECRET=change-me
OIDC_BASE_URL=http://localhost:8000

# --- Keycloak (docker-compose) ---
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Disable the env-admin /token fallback in production once a DB admin exists:
ENV_ADMIN_ENABLED=true
# Public hostname for Keycloak in production mode (`start`, TLS at the nginx proxy).
KC_HOSTNAME=localhost

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- ML ---
ML_MAX_WORKERS=4
ML_MODEL_CACHE_DAYS=7
ML_RETRAIN_HOUR=3

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=change-me

# --- OpenTelemetry ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=sit-center-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- CORS (comma-separated origins for production) ---
CORS_ORIGINS=http://localhost:8050,http://localhost:3000,http://localhost:8000

# --- Airbyte ---
AIRBYTE_VERSION=0.50.4

