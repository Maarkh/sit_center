FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

ENV PYTHONPATH=/app

# Запуск под непривилегированным пользователем (uid/gid 1000), не root.
RUN groupadd -r -g 1000 app && useradd -r -u 1000 -g app -m -d /home/app app \
    && chown -R 1000:1000 /app
USER 1000

CMD ["python", "kafka_consumer_main.py"]
